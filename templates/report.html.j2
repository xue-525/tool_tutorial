<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ title }}</title>
<style>
  :root {
    --fg: #1a1a1a;
    --muted: #6b7280;
    --bg: #ffffff;
    --card: #f8f9fb;
    --accent: #2563eb;
    --border: #e5e7eb;
    --hover: #fff7cc;
  }
  * { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", "Helvetica Neue", sans-serif;
    color: var(--fg);
    background: var(--bg);
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
    line-height: 1.7;
  }
  header h1 { margin: 0 0 .25rem; font-size: 1.85rem; }
  .meta { color: var(--muted); font-size: .9rem; margin-bottom: 2rem; }
  h2 {
    margin-top: 2.5rem;
    padding-bottom: .4rem;
    border-bottom: 2px solid var(--accent);
    font-size: 1.3rem;
  }
  section { margin-bottom: 1.5rem; }
  .summary p { margin: .6rem 0; }
  ul { padding-left: 1.25rem; }
  li { margin: .3rem 0; }
  table { width: 100%; border-collapse: collapse; }
  th, td {
    padding: .5rem .65rem;
    border-bottom: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
  }
  th { background: var(--card); font-weight: 600; }
  .topic {
    padding: .6rem .9rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    margin: .6rem 0;
    background: var(--card);
  }
  .topic h3 { margin: 0 0 .25rem; font-size: 1.05rem; }
  .topic a { color: var(--accent); text-decoration: none; }
  .topic a:hover { text-decoration: underline; }
  .topic .time {
    color: var(--muted);
    font-weight: normal;
    font-size: .85rem;
    margin-left: .4rem;
  }
  .toggle-btn {
    font-size: .85rem;
    padding: .2rem .65rem;
    border: 1px solid var(--border);
    background: #fff;
    cursor: pointer;
    border-radius: 4px;
    margin-left: .6rem;
  }
  .toggle-btn:hover { background: var(--card); }
  .transcript {
    max-height: 600px;
    overflow-y: auto;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: .5rem .8rem;
    background: #fafafa;
  }
  .cue { padding: .25rem 0; font-size: .93rem; }
  .cue .ts {
    display: inline-block;
    min-width: 5.5em;
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: .85rem;
  }
  .cue .speaker { font-weight: 600; color: #444; margin-right: .25rem; }
  .cue:target { background: var(--hover); }
  @media print {
    body { max-width: none; padding: 1rem; }
    .toggle-btn { display: none; }
    .transcript {
      max-height: none;
      overflow: visible;
      border: none;
      padding: 0;
      background: #fff;
    }
  }
</style>
</head>
<body>
<header>
  <h1>{{ title }}</h1>
  <p class="meta">来源:{{ source_name }} · 生成时间:{{ generated_at }}</p>
</header>

{% if summary_html %}
<section class="summary">
  <h2>会议摘要</h2>
  {{ summary_html | safe }}
</section>
{% endif %}

{% if key_points %}
<section>
  <h2>关键要点</h2>
  <ul>
    {% for p in key_points %}<li>{{ p }}</li>{% endfor %}
  </ul>
</section>
{% endif %}

{% if decisions %}
<section>
  <h2>决议事项</h2>
  <ul>
    {% for d in decisions %}<li>{{ d }}</li>{% endfor %}
  </ul>
</section>
{% endif %}

{% if action_items %}
<section>
  <h2>待办事项</h2>
  <table>
    <thead><tr><th>任务</th><th>负责人</th><th>期限</th></tr></thead>
    <tbody>
    {% for a in action_items %}
      <tr><td>{{ a.task }}</td><td>{{ a.owner }}</td><td>{{ a.due }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
</section>
{% endif %}

{% if topics %}
<section>
  <h2>话题分段</h2>
  {% for t in topics %}
    <div class="topic">
      <h3>
        {% if t.anchor is not none %}
          <a href="#t-{{ t.anchor }}">{{ t.title }}</a>
        {% else %}
          {{ t.title }}
        {% endif %}
        <span class="time">[{{ t.start_timestamp }}]</span>
      </h3>
      {% if t.summary %}<p>{{ t.summary }}</p>{% endif %}
    </div>
  {% endfor %}
</section>
{% endif %}

<section>
  <h2>完整字幕 <button class="toggle-btn" onclick="toggleTranscript()">展开/收起</button></h2>
  <div id="transcript" class="transcript">
    {% for c in cues %}
      <div class="cue" id="t-{{ c.start_seconds|int }}">
        <span class="ts">[{{ c.timestamp }}]</span>
        {% if c.speaker %}<span class="speaker">{{ c.speaker }}:</span>{% endif %}
        <span class="text">{{ c.text }}</span>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  function toggleTranscript() {
    var el = document.getElementById('transcript');
    el.style.display = (el.style.display === 'none') ? 'block' : 'none';
  }
</script>
</body>
</html>
